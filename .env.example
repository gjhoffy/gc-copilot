# GC-Copilot Environment Variables
# Copy this file to .env.local and fill in your actual values

# Google Gemini API Key (REQUIRED)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API Key (Optional but recommended)
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Upstash Redis (Optional - for rate limiting)
# Get from: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Allowed Origins for CORS (comma-separated)
# Examples: https://localhost:3000,https://example.com,https://app.example.com
ALLOWED_ORIGINS=https://localhost:3000,https://gc-copilot.vercel.app

# Node Environment
NODE_ENV=development
