{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "functions": {
    "dist/server/*.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/server/server.js"
    }
  ]
}
