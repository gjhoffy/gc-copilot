{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "functions": {
    "dist/server/*.js": {}
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/server/server.js"
    }
  ]
}